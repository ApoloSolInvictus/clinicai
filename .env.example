# Web app
LOCAL_NODE_URL=http://clinic-san-jose.node:8787
LOCAL_NODE_TOKEN=dev-local-node-token
CLINIC_NODE_IDS=clinic-san-jose
CLINIC_NODE_URL_TEMPLATE=http://{clinicSlug}.node:8787
CLINIC_NODE_PUBLIC_URL_TEMPLATE=
CLINIC_NODE_CONFIG_JSON=

# Firebase client
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DEFAULT_CLINIC_ID=clinic-san-jose
FIREBASE_AUTH_DISABLED=false
NEXT_PUBLIC_FIREBASE_AUTH_DISABLED=false

# Persistent central state
OPENCLINIC_STATE_STORE=firestore
OPENCLINIC_STATE_COLLECTION=openclinic
OPENCLINIC_STATE_DOCUMENT=central-state

# Local clinic node
PORT=8787
CLINIC_ID=clinic-san-jose
CLINIC_NAME=Clinica San Jose
CENTRAL_API_URL=http://host.docker.internal:3000/api
OPENCLAW_MODE=mock
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_RUNNER_URL=http://host.docker.internal:18889/run
OPENCLAW_RUNNER_TIMEOUT_MS=30000
